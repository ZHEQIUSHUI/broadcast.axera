#!/bin/sh

APP_NAME=device_broadcast
RUNNER=/var/lib/device_broadcast/device_broadcast_runner.sh
LEGACY_PROG=/usr/bin/device_broadcast
MODERN_PROG=/usr/local/bin/device_broadcast

find_prog() {
    if [ -x "$LEGACY_PROG" ]; then
        echo "$LEGACY_PROG"
        return 0
    fi
    if [ -x "$MODERN_PROG" ]; then
        echo "$MODERN_PROG"
        return 0
    fi
    return 1
}

legacy_start() {
    PROG="$(find_prog)" || exit 0
    printf "Starting %s: " "$APP_NAME"
    if pidof "$APP_NAME" >/dev/null 2>&1; then
        echo "Already running"
        return 0
    fi
    nohup "$PROG" >/dev/null 2>&1 &
    sleep 1
    if pidof "$APP_NAME" >/dev/null 2>&1; then
        echo "OK"
        return 0
    fi
    echo "Failed"
    return 1
}

legacy_stop() {
    printf "Stopping %s: " "$APP_NAME"
    killall -q "$APP_NAME" >/dev/null 2>&1 || true
    echo "OK"
}

legacy_status() {
    if pidof "$APP_NAME" >/dev/null 2>&1; then
        echo "running"
        return 0
    fi
    echo "stopped"
    return 1
}

use_runner() {
    [ -x "$RUNNER" ]
}

case "${1:-start}" in
    start|stop|restart|status)
        if use_runner; then
            exec "$RUNNER" "$1"
        fi
        ;;
    reload)
        if use_runner; then
            exec "$RUNNER" restart
        fi
        ;;
    *)
        echo "usage: $0 {start|stop|restart|reload|status}"
        exit 1
        ;;
esac

case "${1:-start}" in
    start)
        legacy_start
        ;;
    stop)
        legacy_stop
        ;;
    restart|reload)
        legacy_stop
        sleep 1
        legacy_start
        ;;
    status)
        legacy_status
        ;;
esac
